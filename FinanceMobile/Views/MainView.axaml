<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:FinanceMobile.ViewModels"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="FinanceMobile.Views.MainView"
                x:DataType="vm:MainViewModel">
	<!-- Перехватываем событие изменения экрана -->
	<TransitioningContentControl Content="{Binding}"
                                 x:Name="PageHost">
		<!-- Анимация слайда (как в нативном Android) -->
		<TransitioningContentControl.PageTransition>
			<CrossFade Duration="0:0:0.3" />
			<!-- Или используйте SlideTransition для эффекта свайпа -->
		</TransitioningContentControl.PageTransition>
	</TransitioningContentControl>
</UserControl>

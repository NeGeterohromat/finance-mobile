<UserControl xmlns="https://github.com/avaloniaui"
                xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                xmlns:vm="using:FinanceMobile.ViewModels"
                mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
                x:Class="FinanceMobile.Views.MainView"
                x:DataType="vm:MainViewModel">
	<Grid>
		<StackPanel HorizontalAlignment="Center"
					VerticalAlignment="Center"
					Spacing="20">

			<!-- Картинка кота со скруглёнными границами -->
			<Border Width="200" Height="200" CornerRadius="100" ClipToBounds="True">
				<Image Source="avares://FinanceMobile/Assets/cat.png"
					   Stretch="UniformToFill"/>
			</Border>

			<!-- Кнопка-текст -->
			<Button Command="{Binding ToggleGreetingCommand}"
					Background="Transparent"
					BorderThickness="0"
					Padding="10"
					Cursor="Hand">

				<TextBlock Text="{Binding WelcomeMessage}"
						   TextAlignment="Center"
						   TextWrapping="Wrap"
						   FontSize="24"
						   FontWeight="SemiBold"/>
			</Button>
		</StackPanel>
	</Grid>
</UserControl>
